# Backend API
# For mobile development, use your computer's IP address instead of localhost
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.100:8000
EXPO_PUBLIC_API_URL_DEV=http://localhost:8000
EXPO_PUBLIC_API_URL_PROD=https://chat-craft-api.onrender.com
EXPO_PUBLIC_API_URL=http://localhost:8000

# Google OAuth (for future implementation)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# Google Analytics 4
EXPO_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry
EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
EXPO_PUBLIC_ENVIRONMENT=development

# Feedback Form
EXPO_PUBLIC_FEEDBACK_FORM_URL=https://forms.gle/bWYV5a5iGiqabK289
