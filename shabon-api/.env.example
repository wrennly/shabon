# Database (開発: ローカル Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/chatcraft

# Supabase 本番用 (Render無料Postgres → Supabase移行時に使用)
# DATABASE_URL 未設定の場合、アプリは SUPABASE_DATABASE_URL を自動的に利用します。
# 例: サービスロール用パスワードを含む接続文字列 (sslmode=require 必須)
# SUPABASE_DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres?sslmode=require

# Frontend URL (CORS対応)
FRONTEND_URL=http://localhost:3000

# Google API (Gemini Embedding / Chat)
GOOGLE_API_KEY=your_gemini_api_key_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Sentry (Error Monitoring)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
ENVIRONMENT=development

# Admin / Internal Keys (例: メモリクリア等)
# ADMIN_KEY=change_me

# --- 注意事項 ---
# 1. Supabase の anon/public key をサーバー側 .env に入れない（不要）
# 2. Service Role Key は DB接続URLとは別用途。DB接続はパスワードベース。
# 3. 本番では .env を Git 管理外にし、CI/CD の環境変数管理機能を利用すること。
